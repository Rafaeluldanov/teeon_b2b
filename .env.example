# ==========================================================
# Переменные окружения для проекта TEEON
# Скопируйте этот файл в .env.local и заполните значения
# ==========================================================

# Реальный домен сайта — замените перед публикацией!
# Используется для sitemap.xml, canonical-ссылок и Open Graph
NEXT_PUBLIC_SITE_URL=https://teeon.ru

# ID счётчика Яндекс.Метрики
# Создайте счётчик на https://metrika.yandex.ru и вставьте ID
NEXT_PUBLIC_YANDEX_METRIKA_ID=

# Логин владельца административной части
ADMIN_USERNAME=

# Пароль владельца административной части
ADMIN_PASSWORD=

# Секрет для подписи cookie-сессии (не менее 32 символов)
# Сгенерировать: openssl rand -base64 32
ADMIN_SESSION_SECRET=

# ==========================================================
# Настройка отправки заявок с формы
# ==========================================================

# Режим отправки заявок:
#   dev      — сохранять заявки в .tmp/request-submissions/ (по умолчанию)
#   ethereal — отправлять на тестовый Ethereal Email (https://ethereal.email)
#   smtp     — отправлять через реальный SMTP
LEAD_EMAIL_MODE=dev

# SMTP настройки (заполнить при LEAD_EMAIL_MODE=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# Куда приходят заявки (при LEAD_EMAIL_MODE=smtp)
LEAD_TO_EMAIL=
LEAD_FROM_EMAIL=
